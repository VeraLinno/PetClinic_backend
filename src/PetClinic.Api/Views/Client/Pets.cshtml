@model IEnumerable<PetClinic.Application.PetDto>
@{
    Layout = "_ClientLayout";
    ViewData["Title"] = "My Pets";

    var uiTexts = ViewBag.UiTexts as Dictionary<string, string> ?? new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
    string T(string key, string fallback) => uiTexts.TryGetValue(key, out var value) ? value : fallback;
}

<h1 class="h3 mb-3">@T("pets.title", "My Pets")</h1>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-striped mb-0">
            <thead>
                <tr>
                    <th>@T("pets.name", "Name")</th>
                    <th>@T("pets.species", "Species")</th>
                    <th>@T("pets.breed", "Breed")</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pet in Model)
                {
                    <tr>
                        <td>@pet.Name</td>
                        <td>@(pet.SpeciesLocalized ?? pet.Species)</td>
                        <td>@(pet.BreedLocalized ?? pet.Breed)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
