@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-header">
    <div>
        <h1>Cancel Appointment</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/admin/admindashboard">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="/admin/adminappointments">Appointments</a></li>
                <li class="breadcrumb-item active">Cancel</li>
            </ol>
        </nav>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card border-warning">
            <div class="card-header bg-warning text-dark">
                <i class="bi bi-exclamation-triangle"></i> Confirm Cancellation
            </div>
            <div class="card-body">
                <p>Are you sure you want to cancel this appointment?</p>

                @if (Model is not PetClinic.Application.AdminAppointmentDto currentAppt)
                {
                    <div class="alert alert-danger" role="alert">
                        Unable to load appointment details.
                    </div>
                    <a href="/admin/adminappointments" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                }
                else
                {
                    <div class="alert alert-warning">
                        <p class="mb-1"><strong>Pet:</strong> @currentAppt.PetName</p>
                        <p class="mb-1"><strong>Veterinarian:</strong> @currentAppt.VeterinarianName</p>
                        <p class="mb-0"><strong>Scheduled:</strong> @currentAppt.StartAt.ToString("MMM dd, yyyy HH:mm")</p>
                    </div>

                    <form method="post" action="/admin/adminappointments/cancel/@currentAppt.Id">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label">Cancellation Reason</label>
                            <textarea name="reason" class="form-control" rows="3" required></textarea>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-x"></i> Cancel Appointment
                            </button>
                            <a href="/admin/adminappointments/details/@currentAppt.Id" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Back
                            </a>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>
</div>
