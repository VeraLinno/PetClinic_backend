@{
    ViewData["Title"] = "User Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    PetClinic.Application.AdminUserDto? user = null;
    List<PetClinic.Application.AdminAuditLogDto> activity = new();

    if (Model is System.Collections.IList modelItems && modelItems.Count > 0)
    {
        if (modelItems[0] is PetClinic.Application.AdminUserDto modelUser)
        {
            user = modelUser;
        }

        if (modelItems.Count > 1 && modelItems[1] is List<PetClinic.Application.AdminAuditLogDto> modelActivity)
        {
            activity = modelActivity;
        }
    }
}

@if (user is null)
{
    <div class="alert alert-warning" role="alert">
        User details are unavailable.
    </div>
}
else
{
    var currentUser = user!;

    <div class="admin-header">
        <div>
            <h1>@currentUser.FirstName @currentUser.LastName</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/admin/admindashboard">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="/admin/adminusers">Users</a></li>
                    <li class="breadcrumb-item active">Details</li>
                </ol>
            </nav>
        </div>
        <a href="/admin/adminusers/edit/@currentUser.Id" class="btn btn-primary">
            <i class="bi bi-pencil"></i> Edit
        </a>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">User Information</div>
                <div class="card-body">
                    <p><strong>Email:</strong> @currentUser.Email</p>
                    <p><strong>Name:</strong> @currentUser.FirstName @currentUser.LastName</p>
                    <p><strong>Status:</strong> <span class="badge @(currentUser.IsActive ? "bg-success" : "bg-danger")">@(currentUser.IsActive ? "Active" : "Inactive")</span></p>
                    <p><strong>Created:</strong> @currentUser.CreatedAt.ToString("MMM dd, yyyy HH:mm")</p>
                    <p><strong>Last Login:</strong>
                        @if (currentUser.LastLoginAt.HasValue)
                        {
                            @currentUser.LastLoginAt.Value.ToString("MMM dd, yyyy HH:mm")
                        }
                        else
                        {
                            <span class="text-muted">Never</span>
                        }
                    </p>
                    <p><strong>Roles:</strong><br>
                        @if (currentUser.Roles?.Count > 0)
                        {
                            @foreach (var role in currentUser.Roles)
                            {
                                <span class="badge bg-info">@role</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">No roles assigned</span>
                        }
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">Quick Actions</div>
                <div class="card-body">
                    <a href="/admin/adminusers/edit/@currentUser.Id" class="btn btn-warning btn-sm w-100 mb-2">
                        <i class="bi bi-pencil"></i> Edit Roles
                    </a>
                    <a href="/admin/adminaudit/user/@currentUser.Id" class="btn btn-info btn-sm w-100 mb-2">
                        <i class="bi bi-clock-history"></i> View Activity
                    </a>
                    <a href="/admin/adminusers/delete/@currentUser.Id" class="btn btn-danger btn-sm w-100">
                        <i class="bi bi-trash"></i> Delete User
                    </a>
                </div>
            </div>
        </div>
    </div>
}
