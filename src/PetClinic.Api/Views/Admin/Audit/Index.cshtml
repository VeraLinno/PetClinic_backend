@model PetClinic.Api.ViewModels.AdminAuditIndexPageViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var logs = Model.Logs;
}

<div class="admin-header">
    <div>
        <h1>Audit Logs</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/admin/admindashboard">Dashboard</a></li>
                <li class="breadcrumb-item active">Audit</li>
            </ol>
        </nav>
    </div>
    <div>
        <a href="/admin/adminaudit/search" class="btn btn-primary">
            <i class="bi bi-search"></i> Advanced Search
        </a>
    </div>
</div>

<div class="card">
    <div class="card-header">Recent Activity Logs</div>
    <div class="card-body">
        @if (logs?.Count > 0)
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Timestamp</th>
                            <th>User</th>
                            <th>Action</th>
                            <th>Endpoint</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in logs)
                        {
                            <tr>
                                <td>@log.Timestamp.ToString("MMM dd, HH:mm:ss")</td>
                                <td>@log.UserEmail</td>
                                <td>@log.Action</td>
                                <td><code>@log.Endpoint</code></td>
                                <td>
                                    @if (log.StatusCode == 200)
                                    {
                                        <span class="badge bg-success">Success</span>
                                    }
                                    else if (log.StatusCode >= 400 && log.StatusCode < 500)
                                    {
                                        <span class="badge bg-warning">@log.StatusCode</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">@log.StatusCode</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted text-center">No audit logs found</p>
        }
    </div>
</div>
