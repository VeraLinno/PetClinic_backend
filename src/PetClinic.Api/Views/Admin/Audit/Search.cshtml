@{
    ViewData["Title"] = "Search Audit Logs";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var results = Model as List<PetClinic.Application.AdminAuditLogDto> ?? new List<PetClinic.Application.AdminAuditLogDto>();
    var hasResults = results.Count > 0;
}

<div class="admin-header">
    <div>
        <h1>Search Audit Logs</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/admin/admindashboard">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="/admin/adminaudit">Audit Logs</a></li>
                <li class="breadcrumb-item active">Search</li>
            </ol>
        </nav>
    </div>
</div>

<!-- Search Form -->
<div class="card mb-4">
    <div class="card-header">Advanced Search</div>
    <form method="post" class="card-body">
        @Html.AntiForgeryToken()

        <div class="row">
            <div class="col-md-4">
                <label class="form-label">From Date</label>
                <input type="datetime-local" name="FromDate" class="form-control">
            </div>
            <div class="col-md-4">
                <label class="form-label">To Date</label>
                <input type="datetime-local" name="ToDate" class="form-control">
            </div>
            <div class="col-md-4">
                <label class="form-label">User Email</label>
                <input type="email" name="UserEmail" class="form-control" placeholder="owner@example.com">
            </div>
        </div>

        <div class="row mt-3">
            <div class="col-md-4">
                <label class="form-label">Action</label>
                <select name="Action" class="form-select">
                    <option value="">-- All Actions --</option>
                    <option value="Login">Login</option>
                    <option value="BookAppointment">Book Appointment</option>
                    <option value="UpdateProfile">Update Profile</option>
                    <option value="CancelAppointment">Cancel Appointment</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Status Code</label>
                <select name="StatusCode" class="form-select">
                    <option value="">-- All Status Codes --</option>
                    <option value="200">200 - OK</option>
                    <option value="400">400 - Bad Request</option>
                    <option value="401">401 - Unauthorized</option>
                    <option value="403">403 - Forbidden</option>
                    <option value="404">404 - Not Found</option>
                    <option value="500">500 - Server Error</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">&nbsp;</label>
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search"></i> Search
                </button>
            </div>
        </div>
    </form>
</div>

<!-- Search Results -->
@if (hasResults)
{
    var searchResults = results;

    <div class="card">
        <div class="card-header">Search Results (@searchResults.Count logs found)</div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Timestamp</th>
                            <th>User</th>
                            <th>Action</th>
                            <th>Endpoint</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in searchResults.OrderByDescending(l => l.Timestamp))
                        {
                            <tr>
                                <td>@log.Timestamp.ToString("MMM dd, HH:mm:ss")</td>
                                <td>@log.UserEmail</td>
                                <td>@log.Action</td>
                                <td><code>@log.Endpoint</code></td>
                                <td>
                                    @if (log.StatusCode == 200)
                                    {
                                        <span class="badge bg-success">Success</span>
                                    }
                                    else if (log.StatusCode >= 400 && log.StatusCode < 500)
                                    {
                                        <span class="badge bg-warning">@log.StatusCode</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">@log.StatusCode</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No audit logs found matching your search criteria
    </div>
}

<div class="mt-3">
    <a href="/admin/adminaudit" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Back to Audit Logs
    </a>
</div>
